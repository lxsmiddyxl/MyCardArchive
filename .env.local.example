# -----------------------------------------------------------------------------
# MyCardArchive — local environment template
# Copy to `.env.local` and fill in values.
#
# Windows + OneDrive: sync can lock or corrupt `.next` and `node_modules`.
# Prefer cloning the repo outside OneDrive, or exclude this folder from sync,
# for stable `next dev`, `next build`, and Playwright runs.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used for Stripe Checkout / Portal return URLs (production: your real domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role — required for billing API + Stripe webhooks (server only).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe (browser — Checkout.js / Elements if you add them later)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price IDs from Stripe Dashboard or: node scripts/stripe-create-products.mjs
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
STRIPE_PRICE_BUSINESS=

# Optional: when you add yearly prices in Stripe, map them for subscription sync:
# STRIPE_PRICE_PRO_YEARLY=
# STRIPE_PRICE_ELITE_YEARLY=
# STRIPE_PRICE_BUSINESS_YEARLY=

# -----------------------------------------------------------------------------
# Optional — card images (defaults exist in code)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_CARD_STORAGE_BUCKET=card-images

# -----------------------------------------------------------------------------
# Optional — AI / scan (real vision APIs; leave unset to use mocks / fallbacks)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# GOOGLE_API_KEY=
# GEMINI_VISION_MODEL=gemini-1.5-flash
# USE_REAL_MODEL=false

# -----------------------------------------------------------------------------
# Optional — admin / price sync API
# -----------------------------------------------------------------------------
# PRICE_SYNC_SECRET=
# ADMIN_EMAILS=you@example.com,other@example.com

# -----------------------------------------------------------------------------
# Optional — dev-only MCA overlays (realtime panel, health overlay, auth debug strip)
# Default off: `next dev` / `pnpm dev` stays minimal. Set to 1 only when you need those tools.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_MCA_DEV_UI=1

# If your OS or IDE auto-opens a browser on dev start, you can block it (Unix/macOS).
# Windows: set User env var BROWSER=none or rely on IDE settings instead.
# BROWSER=none

# -----------------------------------------------------------------------------
# Optional — telemetry / internal tooling
# -----------------------------------------------------------------------------
# TELEMETRY_INGEST_DISABLED=1
# INTERNAL_TELEMETRY_SECRET=
# NEXT_PUBLIC_APP_VERSION=

# Phase 47 — full-site maintenance (middleware redirects HTML to /maintenance; /api/* returns 503).
# Clear or set false after the window. Stripe webhooks also receive 503 while enabled—plan accordingly.
# MAINTENANCE_MODE=true

# Phase 48–50 — stability / diagnostics / recovery (optional; server + client build-time flags)
# STABILITY_MODE=1
# NEXT_PUBLIC_STABILITY_MODE=1
# RECOVERY_AUTO_HEAL=1
# RECOVERY_AUTO_HEAL=0

# -----------------------------------------------------------------------------
# Playwright E2E (`npm run test:e2e`) — must match dev server URL
# Default in playwright.config.ts is http://127.0.0.1:3000 (see `npm run dev:pw`).
# -----------------------------------------------------------------------------
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
