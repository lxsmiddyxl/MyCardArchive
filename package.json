{
  "name": "my-card-archive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "clean:next": "node scripts/clean-next.mjs",
    "predev": "node scripts/clean-next.mjs",
    "predev:pw": "node scripts/clean-next.mjs",
    "prebuild": "node scripts/clean-next.mjs",
    "dev": "next dev",
    "dev:pw": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"storybook/**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build -o storybook-static",
    "test:e2e": "playwright test",
    "test:e2e:core": "playwright test tests/e2e/core-rls-surfaces.spec.ts",
    "test:e2e:protected": "playwright test tests/e2e/api-protected-routes.spec.ts",
    "test:e2e:launch": "playwright test tests/e2e/smoke.spec.ts tests/e2e/api-protected-routes.spec.ts tests/e2e/trades-dual-account.spec.ts",
    "test:e2e:trades-dual": "playwright test tests/e2e/trades-dual-account.spec.ts",
    "test:unit": "vitest run",
    "stripe:seed-products": "node scripts/stripe-create-products.mjs",
    "stress:realtime": "node scripts/realtime-stress.mjs",
    "health:check": "node scripts/health-check.mjs",
    "predictive:check": "node scripts/predictive-check.mjs",
    "load:check": "node scripts/load-check.mjs",
    "stability:run": "node scripts/stability-runner.mjs",
    "perf:snapshot": "node scripts/perf-snapshot.mjs",
    "deploy:verify": "node scripts/deploy-verify.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-virtual": "^3.13.23",
    "canvas-confetti": "^1.9.4",
    "next": "14.2.18",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "tesseract.js": "^5.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@storybook/addon-a11y": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/nextjs": "^8.4.7",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-mca-design-system": "file:./eslint-plugins/mca-design-system",
    "eslint-plugin-storybook": "^0.11.1",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.4.3",
    "postcss": "^8.4.49",
    "storybook": "^8.4.7",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix",
    "storybook/**/*.{ts,tsx}": "eslint --fix"
  }
}
